# ===== Core =====
NODE_ENV=development
API_PORT=3000

# ===== Control database =====
# Global DB holding tenants, users, encrypted secrets, provisioning state.
CONTROL_DATABASE_URL=postgres://forge:forge@postgres:5432/forge_control

# ===== Tenant database cluster =====
# Admin/base connection used by the provisioner to create + migrate tenant DBs.
# Per-tenant connection strings are stored (encrypted) in the control DB.
TENANT_DB_ADMIN_URL=postgres://forge:forge@postgres:5432/postgres
# create        -> provisioner runs CREATE DATABASE for each tenant
# pre-created   -> empty DBs are pre-created and handed to the provisioner
TENANT_DB_CREATE_MODE=create

# ===== Redis / BullMQ =====
REDIS_URL=redis://redis:6379

# ===== Auth =====
JWT_SECRET=change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ===== Secret encryption =====
# Key used to encrypt tenant connection strings + tool/provider secrets at rest.
# Use a strong 32-byte key in production.
SECRETS_ENCRYPTION_KEY=change-me-32-bytes-minimum-length

# ===== LLM providers =====
LLM_DEFAULT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ===== Frontend =====
WEB_PORT=5173
WIDGET_PORT=5174
PUBLIC_API_URL=http://localhost:3000
